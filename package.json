{
    "name": "zlocker",
    "version": "0.1.0",
    "description": "ZLocker - Digital Identity & Document Verification Platform",
    "main": "backend/src/index.ts",
    "type": "module",
    "scripts": {
      "dev": "pnpm run dev:backend & pnpm run dev:frontend",
      "dev:backend": "cd backend && npm run dev",
      "dev:frontend": "cd frontend && npm run dev",
      "build": "pnpm run build:backend && pnpm run build:frontend",
      "build:backend": "cd backend && npm run build",
      "build:frontend": "cd frontend && npm run build",
      "test": "pnpm run test:backend && pnpm run test:frontend",
      "test:backend": "cd backend && npm run test",
      "test:frontend": "cd frontend && npm run test",
      "test:coverage": "pnpm run test -- --coverage",
      "test:e2e": "cd backend && npm run test:e2e",
      "lint": "pnpm run lint:backend && pnpm run lint:frontend",
      "lint:backend": "cd backend && npm run lint",
      "lint:frontend": "cd frontend && npm run lint",
      "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
      "db:migrate": "cd backend && npm run db:migrate",
      "db:seed": "cd backend && npm run db:seed",
      "docker:up": "docker-compose up --build",
      "docker:down": "docker-compose down",
      "docker:logs": "docker-compose logs -f"
    },
    "keywords": [
      "kyc",
      "identity-verification",
      "document-management",
      "digital-identity",
      "verification",
      "ocr",
      "face-recognition"
    ],
    "author": "ZLocker Team",
    "license": "MIT",
    "repository": {
      "type": "git",
      "url": "https://github.com/hexims/kyaAutomation.git"
    },
    "bugs": {
      "url": "https://github.com/hexims/kyaAutomation/issues"
    },
    "homepage": "https://github.com/hexims/kyaAutomation#readme",
    "workspaces": [
      "backend",
      "frontend",
      "mobile",
      "admin"
    ],
    "devDependencies": {
      "prettier": "^3.0.0",
      "eslint": "^8.0.0",
      "typescript": "^5.0.0"
    }
  }
  